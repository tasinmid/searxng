# Port to bind SearXNG to on the host
SEARXNG_PORT=8080

# IP address / interface to bind to on the host (e.g., 127.0.0.1 or 0.0.0.0)
SEARXNG_HOST=127.0.0.1

# API Key for securing the programmatic /api endpoint
SEARXNG_API_KEY=ultrasecretapikey

# URL for viewing the Web UI
SEARXNG_URL=http://127.0.0.1:8080

# API Endpoint URL to get results programmatically
SEARXNG_API_URL=http://127.0.0.1:8080/api
